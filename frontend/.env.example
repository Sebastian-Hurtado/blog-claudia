# ============================================
# Variables de entorno para el Frontend
# Copia este archivo como .env.local y rellena los valores
# ============================================

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=tu_google_client_id_aqui
GOOGLE_CLIENT_SECRET=tu_google_client_secret_aqui

# NextAuth — genera con: openssl rand -base64 32
AUTH_SECRET=tu_clave_secreta_aqui

# URL del backend Django
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# URL pública del frontend (para NextAuth callbacks)
NEXTAUTH_URL=http://localhost:3000
